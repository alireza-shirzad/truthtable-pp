	keywords = {Databases, query processing, Cascading style sheets, computational complexity, Estimation, graph data, graph theory, long query time cause analysis, NP hardness, Optimization, pattern retrieval, PIGEON, query abortion, query evaluation, query-time information, Runtime, subgraph query progress indicator, subgraph query progress monitoring, user interfaces, Visualization, YouTube},
	pages = {1492--1495},
	file = {IEEE Xplore Abstract Record:/home/ryan/Zotero/storage/KHWWMALM/7113409.html:text/html;Xie et al. - 2015 - PIGEON Progress indicator for subgraph queries.pdf:/home/ryan/Zotero/storage/754U3L2N/Xie et al. - 2015 - PIGEON Progress indicator for subgraph queries.pdf:application/pdf},
