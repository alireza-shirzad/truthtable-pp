}

@inproceedings{cxl_alibaba,
	address = {New York, NY, USA},
	series = {{SIGMOD} '25},
	title = {Unlocking the {Potential} of {CXL} for {Disaggregated} {Memory} in {Cloud}-{Native} {Databases}},
