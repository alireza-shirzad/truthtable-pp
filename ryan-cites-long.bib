@article{asm_lce,
	series = {{SIGMOD} '24},
	title = {{ASM}: {Harmonizing} {Autoregressive} {Model}, {Sampling}, and {Multi}-dimensional {Statistics} {Merging} for {Cardinality} {Estimation}},
	volume = {2},
