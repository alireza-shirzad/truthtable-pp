	keywords = {Computational modeling, Indexes, Optimization, Internet of Things, Edge computing, Base stations, Content delivery, content placement, Cooperative caching, cooperative edge caching, deep deterministic policy gradient (DDPG), double time-scale Markov decision process (DTS-MDP), vehicular edge computing and networks},
	pages = {247--257},
