	file = {Full Text PDF:/home/ryan/Zotero/storage/W5BEKM46/Huang et al. - 2023 - Udon Efficient Debugging of User-Defined Function.pdf:application/pdf},
}

@article{udf_tutorial,
	series = {{VLDB} '23},
