version: 3},
	keywords = {Computer Science - Artificial Intelligence, Computer Science - Databases, Computer Science - Computation and Language},
	file = {Preprint PDF:/home/ryan/Zotero/storage/WY3Z7DKJ/Patel et al. - 2025 - Semantic Operators A Declarative Model for Rich, AI-based Data Processing.pdf:application/pdf;Snapshot:/home/ryan/Zotero/storage/NYHR4P4Z/2407.html:text/html},
}

@article{pgo,
