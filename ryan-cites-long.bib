	pages = {523--535},
	file = {PDF:/home/ryan/Zotero/storage/ZPEWSF5F/Xue and Marcus - 2026 - Global Hash Tables Strike Back! An Analysis of Parallel GROUP BY Aggregation.pdf:application/pdf},
}

