	keywords = {Throughput, Resource management, Internet of Things, Edge computing, Backscatter, Cloud computing, Computation offloading, edge computing, Energy harvesting, Internet of Things (IoT), mobile cloud computing (MCC), mobile edge computing (MEC), Radio frequency, Wireless communication},
	pages = {1584--1607},
