@misc{bolt_arxiv,
	title = {Large {Scale} {Multi}-{Task} {Bayesian} {Optimization} with {Large} {Language} {Models}},
	url = {http://arxiv.org/abs/2503.08131},
	doi = {10.48550/arXiv.2503.08131},
	abstract = {In multi-task Bayesian optimization, the goal is to leverage experience from optimizing existing tasks to improve the efficiency of optimizing new ones. While approaches using multi-task Gaussian processes or deep kernel transfer exist, the performance improvement is marginal when scaling beyond a moderate number of tasks. We introduce a novel approach leveraging large language models (LLMs) to learn from, and improve upon, previous optimization trajectories, scaling to approximately 1500 distinct tasks. Specifically, we propose a feedback loop in which an LLM is fine-tuned on the high quality solutions to specific tasks found by Bayesian optimization (BO). This LLM is then used to generate initialization points for future BO searches for new tasks. The trajectories of these new searches provide additional training data for fine-tuning the LLM, completing the loop. We evaluate our method on two distinct domains: database query optimization and antimicrobial peptide design. Results demonstrate that our approach creates a positive feedback loop, where the LLM's generated initializations gradually improve, leading to better optimization performance. As this feedback loop continues, we find that the LLM is eventually able to generate solutions to new tasks in just a few shots that are better than the solutions produced by "from scratch" by Bayesian optimization while simultaneously requiring significantly fewer oracle calls.},
	urldate = {2025-07-17},
	publisher = {arXiv},
	author = {Zeng, Yimeng and Maus, Natalie and Jones, Haydn Thomas and Tao, Jeffrey and Wan, Fangping and Torres, Marcelo Der Torossian and Fuente-Nunez, Cesar de la and Marcus, Ryan and Bastani, Osbert and Gardner, Jacob R.},
	month = jun,
	year = {2025},
	note = {arXiv:2503.08131 [cs]},
	keywords = {Computer Science - Machine Learning},
	file = {Preprint PDF:/home/ryan/Zotero/storage/F7TGMZ3D/Zeng et al. - 2025 - Large Scale Multi-Task Bayesian Optimization with Large Language Models.pdf:application/pdf;Snapshot:/home/ryan/Zotero/storage/9Y8LTUXM/2503.html:text/html},
}

@inproceedings{onesize,
	address = {Tokoyo, Japan},
	series = {{ICDE} '05},
	title = {"{One} size fits all": an idea whose time has come and gone},
	shorttitle = {"{One} size fits all"},
	url = {https://ieeexplore.ieee.org/document/1410100},
	doi = {10.1109/ICDE.2005.1},
	abstract = {The last 25 years of commercial DBMS development can be summed up in a single phrase: "one size fits all". This phrase refers to the fact that the traditional DBMS architecture (originally designed and optimized for business data processing) has been used to support many data-centric applications with widely varying characteristics and requirements. In this paper, we argue that this concept is no longer applicable to the database market, and that the commercial world will fracture into a collection of independent database engines, some of which may be unified by a common front-end parser. We use examples from the stream-processing market and the data-warehouse market to bolster our claims. We also briefly discuss other markets for which the traditional architecture is a poor fit and argue for a critical rethinking of the current factoring of systems services into products.},
	urldate = {2025-07-17},
